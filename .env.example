# Copy to .env and fill in values:
#   cp .env.example .env
#
# Then start multi mode with:
#   pnpm dev:multi
#   # or: ./scripts/dev-multi.sh

# single | multi (dev:multi forces multi)
BAYKUS_MODE=multi

# Separate from single-mode apps/server/data so libraries don't clash
BAYKUS_DATA_DIR=./data-multi

# TMDB v4 read-access token (JWT) preferred, or a v3 API key (32-char hex).
# Required in multi mode — key stays server-side and never reaches the browser.
BAYKUS_TMDB_API_KEY=

# Optional — password gate (single mode only)
# BAYKUS_PASSWORD=

# Optional — enable IMDb dataset + Serializd scrapers (off by default in multi)
# BAYKUS_ENABLE_SCRAPERS=0

# Optional — Google / Apple OAuth (multi). Comma-separated client IDs;
# first ID is the web client exposed via GET /api/auth/session.
# Append native IDs after the first (014 E122). Mobile may also set
# EXPO_PUBLIC_GOOGLE_* in apps/mobile/.env for Expo Go.
# BAYKUS_GOOGLE_CLIENT_IDS=web-client-id.apps.googleusercontent.com,ios-client-id
# BAYKUS_APPLE_CLIENT_IDS=com.example.web,me.xava.baykus

# Optional — pin Web Push keys (recommended for multi deployments that restart often)
# BAYKUS_VAPID_PUBLIC_KEY=
# BAYKUS_VAPID_PRIVATE_KEY=

# PORT=4004

# Hint for phones (also set the same value in apps/mobile/.env — Metro only
# reads that file for EXPO_PUBLIC_*):
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:4004
