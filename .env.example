# Copy to .env and fill in values:
#   cp .env.example .env
#
# Then start multi mode with:
#   pnpm dev:multi
#   # or: ./scripts/dev-multi.sh

# single | multi (dev:multi forces multi)
BAYKUS_MODE=multi

# Separate from single-mode apps/server/data so libraries don't clash
BAYKUS_DATA_DIR=./data-multi

# TMDB v4 read-access token (JWT) preferred, or a v3 API key (32-char hex).
# Required in multi mode — key stays server-side and never reaches the browser.
BAYKUS_TMDB_API_KEY=

# Optional — password gate (single mode only)
# BAYKUS_PASSWORD=

# Optional — enable IMDb dataset + Serializd scrapers (off by default in multi)
# BAYKUS_ENABLE_SCRAPERS=0

# Optional — pin Web Push keys (recommended for multi deployments that restart often)
# BAYKUS_VAPID_PUBLIC_KEY=
# BAYKUS_VAPID_PRIVATE_KEY=

# PORT=4004
