{
  "name": "baykus",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @baykus/server --filter @baykus/web dev",
    "dev:multi": "bash scripts/dev-multi.sh",
    "build": "pnpm -r build",
    "test": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "storybook": "pnpm --filter @baykus/web storybook"
  },

  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
