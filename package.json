{
  "name": "baykus",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=26"
  },
  "scripts": {
    "api": "pnpm --filter @baykus/server dev",
    "react": "pnpm --filter @baykus/web dev",
    "expo": "pnpm --filter @baykus/mobile start",
    "dev": "pnpm --parallel --filter @baykus/server --filter @baykus/web --filter @baykus/mobile dev",
    "dev:multi": "bash scripts/dev-multi.sh",
    "dev:mobile": "pnpm expo",
    "dev:web": "pnpm --parallel --filter @baykus/server --filter @baykus/web dev",
    "build": "pnpm -r build",
    "test": "vitest run --project unit",
    "test:storybook": "vitest run --project storybook",
    "test:all": "vitest run",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "storybook": "pnpm --filter @baykus/web storybook"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  }
}
